{
  "name": "discursiva-serverless",
  "version": "0.1.0",
  "private": true,
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "serverless": "^3",
    "serverless-localstack": "^1.2",
    "serverless-offline": "^13"
  },
  "scripts": {
    "preinstall": "./preinstall.sh",
    "postinstall": "npm --prefix apps/frontend install && uv sync && cp .env.example .env.local",
    "deploy:local": "dotenv -e .env.local serverless deploy --stage local",
    "remove:local": "docker compose -f docker/docker-compose.localstack.yml down -v"
  }
}